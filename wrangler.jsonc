{
	"name": "astro-practice",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"compatibility_date": "2026-05-23",
	"compatibility_flags": [
		"global_fetch_strictly_public",
		"nodejs_compat"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"observability": {
		"enabled": true
	}
}